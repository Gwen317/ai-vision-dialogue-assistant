{
  "name": "vision-dialogue-backend",
  "version": "1.0.0",
  "description": "Backend gateway for AI Vision Dialogue Assistant",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test:timeline": "ts-node --transpile-only tests/timeline-order.test.ts",
    "test:openrouter:e2e": "ts-node --transpile-only tests/openrouter-e2e.mock.test.ts",
    "test:openrouter:live": "ts-node --transpile-only tests/openrouter-live.smoke.test.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.12.79",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "openai": "^6.42.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
